' DOMAIN ASSOCIATIONS
' ════════════════════════════════════════════════════════

SearchState      "1" o-- "1"    SearchQuery
SearchState      "1" o-- "1"    SearchFilters
SearchState      "1" o-- "*"    SearchResult

ValidationResult "1" o-- "*"    ValidationError
SearchFilters    "1" o-- "0..1" SubjectCriteria
SubjectCriteria  "1" *-- "1"    SubjectDetails

' FilterValidatorFn typedef relations (complete contract)
FilterValidatorFn ..> PartialFilters  : "<<parameter type>>"
FilterValidatorFn ..> ValidationResult : "<<return type>>"
' Single direction: ValidationResult flows UP from AdvancedFilterPanel via @Output validationResult.
' It does NOT flow back down. SearchPageComponent reads SearchState.validationErrors (Map<fieldKey,ValidationError>)
' and passes it as externalValidation: ValidationResult | null to AdvancedFilterPanel.
' These are two distinct values: panel-local (bottom-up) vs facade-authoritative (top-down).
' SearchPageComponent uses facade-authoritative as the source of truth; panel-local is advisory only.

' SubjectDetails concrete flow: SubjectDetailFormComponent builds the concrete subtype
' and emits it via @Output detailsChanged. SubjectFilterComponent assembles SubjectCriteria
' and emits subjectChanged. AdvancedFilterPanel emits it up. SearchPageComponent calls setFilters().

SubjectDetailFormComponent ..> PaiDetails  : "<<creates>> if SubjectType.PAI"
SubjectDetailFormComponent ..> PaeDetails  : "<<creates>> if SubjectType.PAE"
SubjectDetailFormComponent ..> AsDetails   : "<<creates>> if SubjectType.AS"
SubjectDetailFormComponent ..> PgDetails   : "<<creates>> if SubjectType.PG"
SubjectDetailFormComponent ..> PfDetails   : "<<creates>> if SubjectType.PF"
SubjectDetailFormComponent ..> RupDetails  : "<<creates>> if SubjectType.RUP"
SubjectDetailFormComponent ..> SwDetails   : "<<creates>> if SubjectType.SW"

' PartialFilters typedef relations (lives in Domain Model, referenced by Layer 0 IFilterValidator)
PartialFilters ..> SearchFilters        : "<<Omit 'subject'>>"
PartialFilters ..> CommonFilterValues   : "<<contains>>"
PartialFilters ..> DiDaiFilterValues    : "<<contains>>"
PartialFilters ..> AggregateFilterValues : "<<contains>>"
PartialFilters ..> CustomMetaEntry      : "<<contains []>>"
IFilterValidator ..> PartialFilters     : "<<parameter type>>"

IpcCacheService  *--> CacheEntry : "store Map<string, CacheEntry>"
TelemetryService --> LogEntry    : "<<creates>>"

