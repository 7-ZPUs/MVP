' ════════════════════════════════════════════════════════
' LAYER 0 – INTERFACES & CONTRACTS  (ISP + DIP)
' ════════════════════════════════════════════════════════

package "Interfaces & Contracts" #F0FDF4 {

  interface ISearchFacade <<ISP>> {
    + getState(): Signal<SearchState>
    + setQuery(query: SearchQuery): void
    ' Updates query in state only. Does NOT trigger search.
    ' Precondition for search(): must be called before search() to set the query.
    + search(): void
    ' Triggers full-text search using current state.query.
    ' Precondition: state.query must have been set via setQuery() before calling search().
    ' Debounce 300ms applied inside the Facade (toObservable + debounceTime).
    ' No-op if isSearching === true (mutex guard).
    ' CQS: results → Signal<SearchState>.results.
    + setFilters(filters: SearchFilters): void
    ' Updates filters in state only. Does NOT trigger search.
    ' Call searchAdvanced() to apply filters and search.
    + searchAdvanced(filters: SearchFilters): void
    ' Calls setFilters() internally, then triggers advanced search.
    ' CQS: validation errors → Signal<SearchState>.validationErrors, not return value.
    + searchSemantic(query: SearchQuery): void
    + cancelSearch(): void
    + retry(): void
    ' CQS: isSearching guard reflected in Signal<SearchState>.isSearching.
  }

  interface ISearchChannel <<ISP>> {
    + search(q: SearchQuery, s: AbortSignal): Observable<SearchResult[]>
    + searchAdvanced(f: SearchFilters, s: AbortSignal): Observable<SearchResult[]>
    + searchSemantic(q: SearchQuery, s: AbortSignal): Observable<SearchResult[]>
  }

  interface IIndexingChannel <<ISP>> {
    + getIndexingStatus(): Observable<SemanticIndexState>
  }

  interface IFilterValidator <<ISP>> {
    + validate(filters: PartialFilters): ValidationResult
    + validateField(field: string, value: unknown, type: FilterFieldType): ValidationError | null
  }

  interface ISemanticIndexStatus <<ISP>> {
    + getStatus(): Signal<SemanticIndexState>
  }

  interface ICacheService <<ISP>> {
    + get<T>(key: string): T | null
    + set<T>(key: string, value: T, ttlMs: number): void
    + invalidate(key: string): void
    + invalidatePrefix(prefix: string): void
    ' Used by SearchIpcGateway on abort; by IpcCacheService on DIP reload
  }

  interface IErrorHandler <<ISP>> {
    + handle(raw: unknown): AppError
    ' isRecoverable() removed: AppError.recoverable is a public field; callers read it directly.
    + createError(code: ErrorCode, message: string, source: string): AppError
  }

  interface ITelemetry <<ISP>> {
    + trackEvent(name: TelemetryEvent): void
    + trackTiming(metric: TelemetryMetric, ms: number): void
    + trackError(error: AppError): void
  }

  interface ILiveAnnouncer <<ISP>> {
    + announce(message: string, politeness?: "polite"|"assertive"): void
  }

  interface IDocumentFacade <<ISP>> {
    + getFileBlob(documentId: string): Observable<DocumentBlob>
    ' Returns raw binary blob (ArrayBuffer + mimeType). Cached TTL 60s.
    + getDocumentMetadata(documentId: string): Observable<DocumentMetadata>
    ' Returns parsed metadata. Cached TTL 300s.
    + getAipInfo(documentId: string): Observable<AipInfo>
    + getError(): Signal<AppError | null>
    ' loadDocument() removed: was a duplicate of getFileBlob() with identical signature and return type (DRY fix).
  }

  interface ISubjectDetailStrategy <<ISP>> {
    + getFields(): SubjectFieldDefinition[]
    ' Each strategy already IS a specific SubjectType; the type parameter is redundant
    ' and forces implementors to ignore or guard on it (LSP violation). Removed.
  }

  interface IFieldValidatorStrategy <<ISP>> {
    + validate(field: string, value: unknown): ValidationError | null
  }

  interface IRouter <<ISP>> {
    + navigate(commands: (string|number|object)[], extras?: object): Promise<boolean>
    ' Defined here (Layer 0) so Smart Components depend on the abstraction, not Angular Router.
  }

  interface IAngularRouter <<ISP>> {
    ' Minimal wrapper around Angular Router exposing only what AppRouter needs.
    ' Kept in Layer 0 so AppRouter (Layer 3) depends downward on the abstraction.
    ' Concrete binding: provide Angular Router via useExisting in AppModule.
    + navigate(commands: unknown[], extras?: object): Promise<boolean>
  }

  interface IElectronContextBridge <<ISP>> {
    + invoke<T>(channel: string, payload: unknown, s?: AbortSignal): Promise<T>
    ' Abstraction over Electron contextBridge.exposeInMainWorld.
    ' Implemented by a thin wrapper injected at bootstrap; mock-replaced in tests.
  }

  interface ILoggingChannel <<ISP>> {
    + writeLog(entry: LogEntry): Observable<void>
  }
}

' ════════════════════════════════════════════════════════
' SHARED KERNEL & EXTERNAL REFERENCES
' ════════════════════════════════════════════════════════

package "Shared Kernel  «cross-cutting»" #F5F3FF {
  interface IDipReadyChecker <<ISP>> {
    + isReady(): boolean
  }
}

package "External Module References" #F0F0F0 {
  class DocumentFacade <<ExternalModule>> <<Service>> {
    + getFileBlob(documentId: string): Observable<DocumentBlob>
    + getDocumentMetadata(documentId: string): Observable<DocumentMetadata>
    + getAipInfo(documentId: string): Observable<AipInfo>
    + getError(): Signal<AppError | null>
    ' loadDocument() removed: duplicate of getFileBlob() (DRY fix).
  }
}

' ════════════════════════════════════════════════════════
' LAYER 1 – DOMAIN MODEL  (DTOs / Value Objects)
' ════════════════════════════════════════════════════════

package "Domain Model" #FFF7ED {

  class SearchQuery <<DTO>> {
    + text: string
    + type: SearchQueryType
    ' Changed from literal union to enum for consistency with the rest of the domain model.
    + useSemantic: boolean
  }

  enum SearchQueryType {
    FREE · CLASS_NAME · PROCESS_ID
  }

  class SearchFilters <<DTO>> {
    + common: CommonFilterValues
    + diDai: DiDaiFilterValues
    + aggregate: AggregateFilterValues
    + customMeta: CustomMetaEntry[]
    + subject: SubjectCriteria | null
  }

  class SearchResult <<DTO>> {
    + documentId: string
    + name: string
    + type: string
    + score: number | null
  }

  class SearchState <<StateModel>> {
    + query: SearchQuery
    + filters: SearchFilters
    + results: SearchResult[]
    + loading: boolean
    ' true while any async operation is in flight (search OR document load).
    ' Drives AsyncStateWrapperComponent @Input loading. Reset in finally of every async call.
    + isSearching: boolean
    ' Mutex: true exclusively during IPC search call (search/searchAdvanced/searchSemantic).
    ' Prevents concurrent searches. Reset in finally of the search call only.
    ' Distinct from loading: loading can be true for document loads; isSearching only for search IPC.
    + error: AppError | null
    + validationErrors: Map<string, ValidationError>
    ' key = fieldKey, matching ValidationError.field.
    ' Populated by SearchFacade on pre-validation failure (UC-10, UC-18).
    ' Read by SearchPageComponent → passed as externalValidation to AdvancedFilterPanel.
  }

  class AppError <<DTO>> {
    + code: ErrorCode
    + category: ErrorCategory
    + severity: ErrorSeverity
    + recoverable: boolean
    ' true → show "Riprova"; false → show "Chiudi" only
    + message: string
    + source: string
    + context: string | null
    ' e.g. filename, nodeId, field name
    + detail: string | null
    ' technical message for debug
  }

  enum ErrorCategory {
    IPC · VALIDATION · DOMAIN · IO · PRINT
  }

  enum ErrorSeverity {
    FATAL · ERROR · WARN · INFO
  }

  class ValidationResult <<DTO>> {
    + isValid: boolean
    + errors: Map<string, ValidationError>
    ' key = ValidationError.field (same value as the contained object's .field property).
    ' Redundancy is intentional for O(1) lookup by fieldKey without iterating the collection.
  }

  class ValidationError <<DTO>> {
    + field: string
    + message: string
    + code: string
  }

  class SemanticIndexState <<DTO>> {
    + status: IndexingStatus
    + progress: number
    + lastIndexedAt: Date | null
  }

  class SubjectCriteria <<DTO>> {
    + role: SubjectRole
    + type: SubjectType
    + details: SubjectDetails
  }

  class DocumentBlob <<DTO>> {
    + data: ArrayBuffer
    + mimeType: string
  }

  class DocumentMetadata <<DTO>> {
    + documentId: string
    + name: string
    + type: string
    + createdAt: Date
    + updatedAt: Date
    + classification: string | null
    + conservation: string | null
  }

  class AipInfo <<DTO>> {
    + aipId: string
    + version: string
    + createdAt: Date
    + checksumAlgorithm: string
    + checksumValue: string
  }

  enum IndexingStatus {
    IDLE · INDEXING · READY · ERROR · TIMEOUT
  }

  enum FilterFieldType {
    TEXT · DATE · NUMBER · ENUM · BOOLEAN
  }

  enum TelemetryEvent {
    SEARCH_EXECUTED
    SEARCH_RESULT_OPENED
    IPC_ERROR
  }

  enum TelemetryMetric {
    SEARCH_LATENCY_MS
    BLOB_LOAD_TIME_MS
  }

  enum ErrorCode {
    VALIDATION_ERROR
    SEARCH_ENGINE_ERROR · IPC_ERROR
    DOC_FORMAT_UNSUPPORTED · DOC_BLOB_LOAD_ERROR
    DIP_CORRUPT_ARCHIVE · DIP_PARSE_ERROR · DIP_INDEX_ERROR
  }

  enum SubjectRole {
    PRODUTTORE · DESTINATARIO · RESPONSABILE
  }

  enum SubjectType {
    PAI · PAE · AS · PG · PF · RUP · SW
  }

  abstract class SubjectDetails { }

  class PaiDetails <<DTO>> extends SubjectDetails {
    + codiceAmministrazione: string
    + denominazione: string
    + codiceFiscale: string | null
  }
  class PaeDetails <<DTO>> extends SubjectDetails {
    + denominazione: string
    + paese: string
    + identificativo: string | null
  }
  class AsDetails <<DTO>> extends SubjectDetails {
    + denominazione: string
    + codiceUfficio: string | null
  }
  class PgDetails <<DTO>> extends SubjectDetails {
    + denominazione: string
    + codiceFiscale: string
    + partitaIva: string | null
  }
  class PfDetails <<DTO>> extends SubjectDetails {
    + cognome: string
    + nome: string
    + codiceFiscale: string | null
  }
  class RupDetails <<DTO>> extends SubjectDetails {
    + cognome: string
    + nome: string
    + codiceFiscale: string | null
    + matricola: string | null
  }
  class SwDetails <<DTO>> extends SubjectDetails {
    + prodotto: string
    + versione: string
    + fornitore: string | null
  }

  class SubjectFieldDefinition <<DTO>> {
    + key: string
    + label: string
    + type: FilterFieldType
    + required: boolean
  }

  class CommonFilterValues <<DTO>> {
    + chiaveDescrittiva: string | null
    + classificazione: string | null
    + conservazione: string | null
    + note: string | null
    + tipo: string | null
  }

  class DiDaiFilterValues <<DTO>> {
    + registrazione: string | null
    + tipologia: string | null
    + formazione: string | null
    + riservatezza: string | null
    + formato: string | null
    + verifica: boolean | null
    + nome: string | null
    + versione: string | null
    + idPrimario: string | null
    + tracciature: string | null
  }

  class AggregateFilterValues <<DTO>> {
    + tipo: string | null
    + idAggregazione: string | null
    + fascicolo: string | null
    + dataDa: string | null
    + dataA: string | null
    + procedimento: string | null
    + assegnazione: string | null
  }

  class CustomMetaEntry <<DTO>> {
    + name: string
    + value: string
  }

  class CacheEntry <<DTO>> {
    + value: unknown
    + expiresAt: number
    ' Absolute timestamp: expiresAt = Date.now() + ttlMs (set at write time).
    ' ICacheService.get() evicts automatically when Date.now() > expiresAt.
  }

  class LogEntry <<DTO>> {
    + level: LogLevel
    ' Changed from literal union to enum for consistency with the rest of the domain model.
    + event: string
    + timestamp: number
    + payload: unknown
  }

  enum LogLevel {
    INFO · WARN · ERROR
  }

  class PartialFilters <<typedef>> {
    ' = Omit<SearchFilters, "subject">
    ' Moved here from Interfaces & Contracts: it is a domain type, not a behavioural contract.
    ' Subject validation is the wizard's responsibility (SubjectFilterComponent).
    ' FilterValidatorService validates only structural/format fields.
    + common: CommonFilterValues
    + diDai: DiDaiFilterValues
    + aggregate: AggregateFilterValues
    + customMeta: CustomMetaEntry[]
  }

  class FilterValidatorFn <<typedef>> {
    ' = (filters: PartialFilters) => ValidationResult
    ' Moved here from Interfaces & Contracts: it is a domain function type, not a contract.
    ' Created by SearchPageComponent from IFilterValidator.validate.bind(validator).
    ' Passed as @Input validator to AdvancedFilterPanelComponent; never injected into Dumb components.
  }
}

' ════════════════════════════════════════════════════════
' LAYER 2 – SERVICES  (SRP · DIP)
' ════════════════════════════════════════════════════════

package "Services  [providedIn:'root']" #EFF6FF {

  class SearchFacade <<Service>> <<SRP>> {
    - ipcGateway: ISearchChannel
    - validator: IFilterValidator
    - errorHandler: IErrorHandler
    - telemetry: ITelemetry
    - semanticStatus: ISemanticIndexStatus
    - liveAnnouncer: ILiveAnnouncer  <<inject>>
    ' ICacheService removed: cache is SearchIpcGateway's internal responsibility (SRP/layer fix).
    - state: WritableSignal<SearchState>
    - abortController: AbortController | null
    ' Lifecycle: created at the start of search(), searchAdvanced(), searchSemantic().
    ' Previous controller aborted before replacement (ensures only one active IPC call).
    ' Passed as AbortSignal to ISearchChannel methods. Set to null in finally block.
    --
    + getState(): Signal<SearchState>
    + setQuery(query: SearchQuery): void
    ' Updates state.query only. Precondition for search(). Does NOT trigger search.
    + search(): void
    ' Creates new AbortController, aborts previous if any, passes signal to ISearchChannel.search().
    ' Debounce 300ms (toObservable+debounceTime). No-op if isSearching===true.
    ' Sets state.loading=true, state.isSearching=true; resets both in finally.
    + setFilters(filters: SearchFilters): void
    ' Updates state.filters only. Does NOT trigger search.
    + searchAdvanced(filters: SearchFilters): void
    ' Calls setFilters(filters) internally, then creates AbortController and calls ISearchChannel.searchAdvanced().
    ' On pre-validation failure: populates state.validationErrors; does NOT create AbortController or call IPC.
    ' On success: clears state.validationErrors.
    + searchSemantic(query: SearchQuery): void
    + cancelSearch(): void
    ' Calls abortController.abort() if not null; sets state.isSearching=false, state.loading=false.
    + retry(): void
  }

  class SemanticIndexFacade <<Service>> <<SRP>> {
    - ipcGateway: IIndexingChannel
    - state: WritableSignal<SemanticIndexState>
    - timeoutMs: number
    ' Default: 120_000 ms. Configurable. When elapsed → status = TIMEOUT → graceful degradation.
    - timeoutHandle: ReturnType<typeof setTimeout> | null
    --
    + getStatus(): Signal<SemanticIndexState>
  }

  class FilterValidatorService <<Service>> <<SRP>> {
    - validators: Map<FilterFieldType, IFieldValidatorStrategy>
    ' Provided via FILTER_VALIDATOR_STRATEGIES InjectionToken (see token declaration below).
    ' Angular cannot inject a generic Map<K,V> directly; a factory provider builds the Map
    ' from an array of {fieldType, strategy} pairs registered with the token.
    + validate(filters: PartialFilters): ValidationResult
    + validateField(f: string, v: unknown, t: FilterFieldType): ValidationError | null
  }

  note as FilterValidatorStrategyToken
    InjectionToken<{fieldType: FilterFieldType, strategy: IFieldValidatorStrategy}[]>
    FILTER_VALIDATOR_STRATEGIES
    — registered in SearchModule providers as multi:true entries.
    FilterValidatorService constructor receives the array and builds the internal Map.
  end note

  class IpcErrorHandlerService <<Service>> <<SRP>> {
    + handle(raw: unknown): AppError
    ' isRecoverable() removed: redundant with AppError.recoverable (DRY fix).
    + createError(code: ErrorCode, message: string, source: string): AppError
    - toErrorCode(raw: unknown): ErrorCode
  }

  class TelemetryService <<Service>> <<SRP>> {
    - loggingChannel: ILoggingChannel  <<inject>>
    + trackEvent(name: TelemetryEvent): void
    + trackTiming(metric: TelemetryMetric, ms: number): void
    + trackError(error: AppError): void
  }

  class LiveAnnouncerService <<Service>> <<SRP>> {
    + announce(message: string, politeness?: "polite"|"assertive"): void
  }
}

' ════════════════════════════════════════════════════════
' LAYER 2b – ADAPTERS / INFRASTRUCTURE
'  Concrete IPC adapters. Depend on IElectronContextBridge.
'  Kept separate from domain Services to respect layer boundaries.
' ════════════════════════════════════════════════════════

package "Adapters  «Infrastructure»" #F0F4FF {
  ' All classes here implement interfaces from Layer 0 and depend on IElectronContextBridge.
  ' Kept separate from domain Services to enforce layer boundaries.

  class SearchIpcGateway <<Adapter>> {
    ' Implements: ISearchChannel
    - contextBridge: IElectronContextBridge
    - cache: ICacheService
    - errorHandler: IErrorHandler
    --
    + search(q: SearchQuery, s: AbortSignal): Observable<SearchResult[]>
    + searchAdvanced(f: SearchFilters, s: AbortSignal): Observable<SearchResult[]>
    + searchSemantic(q: SearchQuery, s: AbortSignal): Observable<SearchResult[]>
    - cancelAndInvalidate(cacheKeyPrefix: string): void
    ' Private: triggered when AbortSignal fires. Calls ICacheService.invalidatePrefix().
    - invoke<T>(channel: string, payload: unknown, s: AbortSignal): Observable<T>
  }

  class IndexingIpcGateway <<Adapter>> {
    ' Implements: IIndexingChannel
    - contextBridge: IElectronContextBridge
    - errorHandler: IErrorHandler
    --
    + getIndexingStatus(): Observable<SemanticIndexState>
    - invoke<T>(channel: string, payload: unknown): Observable<T>
  }

  class ElectronLoggingGateway <<Adapter>> {
    ' Implements: ILoggingChannel
    ' Writes structured log entries to rotating file via IPC writeLog [no-cache].
    - contextBridge: IElectronContextBridge  <<inject>>
    --
    + writeLog(entry: LogEntry): Observable<void>
  }

  class IpcCacheService <<Adapter>> {
    ' Implements: ICacheService
    ' In-memory TTL cache for IPC search results. Infrastructure concern, not domain logic.
    ' Moved from Services: has no domain behaviour, purely manages a Map<string, CacheEntry>.
    - store: Map<string, CacheEntry>
    --
    + get<T>(key: string): T | null
    + set<T>(key: string, value: T, ttlMs: number): void
    + invalidate(key: string): void
    + invalidatePrefix(prefix: string): void
    ' Removes all entries whose key starts with prefix (e.g. "search/" on DIP reload).
  }
}

' ════════════════════════════════════════════════════════
' LAYER 3 – ROUTING
' ════════════════════════════════════════════════════════

package "Routing" #FDF4FF {
  ' IRouter and IAngularRouter interfaces are in "Interfaces & Contracts" (Layer 0).

  class AppRouter <<Service>> {
    ' Implements IRouter (Layer 0). Depends on IAngularRouter (Layer 0 minimal wrapper)
    ' rather than the concrete Angular Router class, preserving testability.
    ' Concrete binding: { provide: IAngularRouter, useExisting: Router } in AppModule.
    - angularRouter: IAngularRouter  <<inject>>
    --
    + navigate(commands: (string|number|object)[], extras?: object): Promise<boolean>
  }

  class DipReadyGuard <<CanActivateFn>> <<function>> {
    ' Angular 15+ functional guard; uses inject() internally.
    - checker: IDipReadyChecker  <<inject()>>
    ' If checker.isReady() === false → redirects to loading screen; route not activated.
    + canActivate(): boolean | UrlTree
  }
}

' ════════════════════════════════════════════════════════
' LAYER 4a – SMART COMPONENTS  «Container»
' ════════════════════════════════════════════════════════

skinparam class {
  HeaderBackgroundColor #BFDBFE
  BorderColor           #1D4ED8
}

package "Smart Components  «Container»" #EFF6FF {

  class SearchPageComponent <<Smart>> {
    - searchFacade:      ISearchFacade          <<inject>>
    - router:            IRouter                <<inject>>
    - semanticStatus:    ISemanticIndexStatus   <<inject>>
    - filterValidator:   IFilterValidator       <<inject>>

    ~ documentViewer: DocumentViewerComponent  [@ViewChild]
    ' @ViewChild used only for imperative reset on new search; never for data flow.

    - selectedDocumentId:  WritableSignal<string | null>
    - viewerError:         WritableSignal<AppError | null>
    - unsupportedMimeType: WritableSignal<string | null>
    ' Set when PreviewPanelComponent emits unsupportedFormat (via DocumentViewerComponent).
    ' Drives an InlineErrorComponent slot in the viewer area showing the unsupported format message.
    ' uiValidation removed: validation errors now live in Signal<SearchState>.validationErrors.

    ~ searchState:    Signal<SearchState>        [read-only]
    ~ indexingState:  Signal<SemanticIndexState> [via semanticStatus.getStatus()]
    ~ isEmpty:        Signal<boolean>
    ~ validatorFn:    FilterValidatorFn
    ' Produced once in constructor: IFilterValidator.validate.bind(filterValidator).
    ' Stable reference — safe to pass as @Input without triggering change detection on each render.

    + onQueryChanged(query: SearchQuery): void
    + onFiltersChanged(filters: SearchFilters): void
    ' Keeps local SearchFilters copy in sync with incremental panel changes. Does NOT call searchAdvanced().
    + onFiltersSubmit(filters: SearchFilters): void
    ' Calls searchFacade.searchAdvanced(filters). Single trigger point for advanced search.
    + onValidationResult(result: ValidationResult): void
    ' Advisory only: used to enable/disable the submit button in the panel area.
    ' Does NOT update SearchState. Source of truth for validation errors is SearchState.validationErrors.

    + onResultSelected(documentId: string): void
    + onRetrySearch(): void
    + onViewerError(err: AppError): void
    + onViewerRetry(): void
    + onUnsupportedFormat(mimeType: string): void
    ' Receives unsupportedFormat event propagated from DocumentViewerComponent.
    ' Sets unsupportedMimeType signal → drives InlineErrorComponent in viewer slot.
  }

  class DocumentViewerComponent <<Smart>> {
    - documentFacade: IDocumentFacade  <<inject>>
    - isLoading: WritableSignal<boolean>
    - documentBlob:     WritableSignal<DocumentBlob | null>
    - documentMetadata: WritableSignal<DocumentMetadata | null>
    - aipInfo:          WritableSignal<AipInfo | null>
    ' All three fetched from IDocumentFacade on documentId @Input change (parallel via forkJoin).
    ' All three passed as @Input to PreviewPanelComponent (Dumb child).

    + @Input  documentId: string
    + @Output loadingChanged: EventEmitter<boolean>
    + @Output viewerError: EventEmitter<AppError>
    + @Output unsupportedFormat: EventEmitter<string>
    ' Propagates PreviewPanelComponent.unsupportedFormat upward to SearchPageComponent.
    ' SearchPageComponent.onUnsupportedFormat() handles it by setting unsupportedMimeType signal.
    + retryLoad(): void
    - onLoadError(err: AppError): void
    - onUnsupportedFormat(mimeType: string): void
    ' Internal handler: receives from PreviewPanelComponent, re-emits via @Output unsupportedFormat.
  }
}

' ════════════════════════════════════════════════════════
' LAYER 4b – DUMB COMPONENTS  «Presentational»
' ════════════════════════════════════════════════════════

skinparam class {
  HeaderBackgroundColor #BBF7D0
  BorderColor           #15803D
}

package "Dumb Components  «Presentational»" #F0FDF4 {

  class SearchBarComponent <<Dumb>> {
    + @Input  query: SearchQuery
    ' query.type and query.useSemantic carry the current values; no separate defaults needed.
    ' SearchPageComponent initialises SearchQuery with sensible defaults before first bind.
    + @Input  isSearching: boolean
    + @Output queryChanged: EventEmitter<SearchQuery>
  }

  class AdvancedFilterPanelComponent <<Semi-Smart>> {
    ' Semi-Smart: owns local UI state (expanded/collapsed, current validation result)
    ' but does NOT inject Facade services. State is purely presentational.
    + @Input  filters: SearchFilters
    + @Input  validator: FilterValidatorFn
    + @Input  externalValidation: ValidationResult | null
    ' externalValidation = SearchState.validationErrors projected by SearchPageComponent.

    + @Input  strategyRegistry: Map<SubjectType, ISubjectDetailStrategy>
    ' Passed through to SubjectFilterComponent → SubjectDetailFormComponent (never consumed here).

    + @Output filtersChanged: EventEmitter<SearchFilters>
    ' Emitted on every incremental field change (live update, no confirmation).
    ' SearchPageComponent uses it to keep its local SearchFilters in sync.

    + @Output filtersSubmit: EventEmitter<SearchFilters>
    ' Emitted only on explicit user submit action (e.g. "Cerca" button click).
    ' SearchPageComponent calls searchAdvanced() only on this event, not on filtersChanged.

    + @Output validationResult: EventEmitter<ValidationResult>
    + @Output filterAdded: EventEmitter<CustomMetaEntry>
    ' SearchPageComponent enforces name uniqueness before adding: rejects if customMeta already contains same name.
    + @Output filterRemoved: EventEmitter<string>
    ' Payload = CustomMetaEntry.name (the user-defined metadata key).
    ' CustomMetaEntry.name is the stable unique identifier within customMeta[].
    ' Uniqueness invariant enforced at add time by SearchPageComponent; safe to use as removal key.
    + @Output filtersReset: EventEmitter<void>
    ' Mutations emitted upward; SearchPageComponent applies them to SearchFilters and re-binds via @Input.

    - isExpanded: boolean
    - currentValidationResult: ValidationResult | null
    ' Local UI-only state: not domain state.
    --
    + onCommonFiltersChanged(values: CommonFilterValues): void
    + onDiDaiFiltersChanged(values: DiDaiFilterValues): void
    + onAggregateFiltersChanged(values: AggregateFilterValues): void
    + onEntriesChanged(entries: CustomMetaEntry[]): void
    + onSubjectChanged(subject: SubjectCriteria): void
    + onFieldValidationError(field: string, error: ValidationError | null): void
  }
  
  class SubjectFilterComponent <<Stateful-Dumb>> {
    ' Stateful-Dumb: local UI state (wizard steps) only.
    ' No Facade injection. WritableSignals are purely presentational (step navigation).
    ' Domain output (SubjectCriteria) always emitted upward via @Output.
    ' strategyRegistry received from SearchPageComponent via AdvancedFilterPanel and passed down.
    - currentStep:  WritableSignal<1|2|3>
    - selectedRole: WritableSignal<SubjectRole | null>
    - selectedType: WritableSignal<SubjectType | null>
    --
    + @Input  subject: SubjectCriteria | null
    + @Input  resetCounter: number
    + @Input  strategyRegistry: Map<SubjectType, ISubjectDetailStrategy>
    + @Output subjectChanged: EventEmitter<SubjectCriteria>
    + nextStep(): void
    + prevStep(): void
    + reset(): void
  }

  class CommonFiltersComponent <<Dumb>> {
    + @Input  filters: CommonFilterValues
    + @Input  validationResult: ValidationResult
    + @Output filtersChanged: EventEmitter<CommonFilterValues>
    + @Output validationError: EventEmitter<{field: string; error: ValidationError | null}>
    + onValueChanged(fieldKey: string, value: unknown): void
    + onValidationError(field: string, error: ValidationError | null): void
  }

  class DiDaiFiltersComponent <<Dumb>> {
