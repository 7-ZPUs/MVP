{
  "name": "dip-viewer",
  "version": "0.1.0",
  "description": "DIP Viewer – Electron desktop application for reading and searching DIP packages",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "build:renderer": "cd renderer && ng build",
    "build:all": "npm run build:renderer && npm run build",
    "start": "electron .",
    "start:renderer": "cd renderer && ng serve",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:renderer": "cd renderer && ng test"
  },
  "dependencies": {
    "adm-zip": "^0.5.10",
    "better-sqlite3": "^9.4.3",
    "electron": "^30.0.0",
    "fast-xml-parser": "^4.3.6",
    "reflect-metadata": "^0.2.2",
    "sqlite-vss": "^0.1.2",
    "tsyringe": "^4.8.0",
    "@xenova/transformers": "^2.17.2",
    "onnxruntime-node": "^1.17.3"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.12.7",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  }
}
