{
  "name": "dip-viewer",
  "version": "0.1.0",
  "description": "DIP Viewer – Electron desktop application for reading and searching DIP packages",
  "main": "dist/main.js",
  "scripts": {
    "setup:download-models": "ts-node --project tsconfig.json core/src/scripts/download-models.ts",
    "copy:models": "cpx \"core/src/models/**/*\" dist/core/src/models",
    "build:core": "tsc --project tsconfig.core.json && npm run copy:models",
    "build:renderer": "cd renderer && npx ng build",
    "build:main": "tsc --project tsconfig.json",
    "build:all": "npm run build:renderer && npm run build:core && npm run build:main",
    "start": "ELECTRON_DISABLE_SANDBOX=1 electron .",
    "start:lore": "DBUS_SESSION_BUS_ADDRESS=/dev/null ELECTRON_DISABLE_SANDBOX=1 electron .",
    "start:dev": "npm run build:all && NODE_ENV=development npm run start",
    "start:renderer": "cd renderer && ng serve --host 0.0.0.0",
    "test:system": "vitest run shared/system_test",
    "test:core": "vitest run --passWithNoTests --watch=false",
    "test:core:watch": "vitest",
    "test:core:coverage": "vitest run --passWithNoTests --coverage",
    "test:renderer": "cd renderer && npx ng test --watch=false",
    "test:renderer:coverage": "cd renderer && npx ng test --watch=false --coverage",
    "test": "npm run test:core && npm run test:renderer",
    "test:coverage": "npm run test:core:coverage && npm run test:renderer:coverage",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "dependencies": {
    "@angular/animations": "^21.2.6",
    "@angular/router": "^21.2.6",
    "@huggingface/transformers": "^3.8.1",
    "@xenova/transformers": "^2.17.2",
    "adm-zip": "^0.5.10",
    "better-sqlite3": "^12.8.0",
    "electron": "^30.0.0",
    "fast-xml-parser": "^4.3.6",
    "onnxruntime-node": "^1.17.3",
    "reflect-metadata": "^0.2.2",
    "sharp": "^0.34.5",
    "sqlite-vss": "^0.1.2",
    "tsyringe": "^4.8.0"
  },
  "devDependencies": {
    "@angular/cli": "^21.2.5",
    "@types/adm-zip": "^0.5.5",
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.19.37",
    "@vitest/coverage-v8": "^1.6.1",
    "cpx": "^1.5.0",
    "defaults": "^3.0.0",
    "electron": "^30.0.0",
    "electron-rebuild": "^3.2.9",
    "eslint": "^10.0.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "vitest": "^1.6.1"
  }
}
