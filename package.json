{
  "name": "dip-viewer",
  "version": "0.1.0",
  "description": "DIP Viewer – Electron desktop application for reading and searching DIP packages",
  "main": "dist/main.js",
  "scripts": {
    "setup:download-models": "ts-node --project tsconfig.json core/src/scripts/download-models.ts",
    "build:core": "tsc --project tsconfig.core.json",
    "build:renderer": "cd renderer && npx ng build",
    "build:all": "npm run build:renderer && npm run build:core",
    "start": "ELECTRON_DISABLE_SANDBOX=1 electron .",
    "start:renderer": "cd renderer && ng serve --host 0.0.0.0",
    "test": "npm run test:core",
    "test:core": "vitest run",
    "test:renderer": "cd renderer && ng test"
  },
  "dependencies": {
    "@angular/router": "^21.2.6",
    "adm-zip": "^0.5.10",
    "fast-xml-parser": "^4.3.6",
    "reflect-metadata": "^0.2.2",
    "sqlite-vss": "^0.1.2",
    "tsyringe": "^4.8.0"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@xenova/transformers": "^2.17.2",
    "onnxruntime-node": "^1.17.3"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.12.7",
    "@vitest/coverage-v8": "^1.6.1",
    "better-sqlite3": "^9.6.0",
    "electron": "^30.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.56.1",
    "vitest": "^1.5.0"
  }
}